<script>
    document.addEventListener('DOMContentLoaded', () => {
        // 1. Staggered Entrance Animation
        const infoPanel = document.querySelector('.info-panel') as HTMLElement;
        const inquiryPanel = document.querySelector('.inquiry-panel') as HTMLElement;
        
        if (infoPanel && inquiryPanel) {
            infoPanel.style.opacity = '0';
            infoPanel.style.transform = 'translateY(30px)';
            inquiryPanel.style.opacity = '0';
            inquiryPanel.style.transform = 'translateY(30px)';
            
            infoPanel.style.transition = 'opacity 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.1s, transform 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.1s';
            inquiryPanel.style.transition = 'opacity 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.25s, transform 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.25s';
            
            requestAnimationFrame(() => {
                infoPanel.style.opacity = '1';
                infoPanel.style.transform = 'translateY(0)';
                inquiryPanel.style.opacity = '1';
                inquiryPanel.style.transform = 'translateY(0)';
            });
        }

        // 2. Cursor Haptic Snap Classes
        const cursor = document.querySelector('.custom-cursor');
        const interactiveElements = document.querySelectorAll('.magnetic, input, select, textarea, button, a');
        
        interactiveElements.forEach(el => {
            el.addEventListener('mouseenter', () => {
                cursor?.classList.add('haptic-snap');
            });
            el.addEventListener('mouseleave', () => {
                cursor?.classList.remove('haptic-snap');
            });
        });

        // 3. WhatsApp & WeChat Click Constructors
        document.querySelector('.whatsapp')?.addEventListener('click', (e) => {
            e.preventDefault();
            const pt = ["86", "185", "7875", "5540"];
            window.open("https://wa.me/" + pt.join(''), "_blank");
        });

        document.querySelector('.wechat')?.addEventListener('click', (e) => {
            e.preventDefault();
            const pt = ["86", "185", "7875", "5540"];
            window.location.href = "tel:+" + pt.join('');
        });

        // 4. Netlify Form Submission Handling
        const b2bForm = document.getElementById('b2b-form') as HTMLFormElement;
        const formLoader = document.getElementById('form-loader');

        if (b2bForm && formLoader) {
            b2bForm.addEventListener('submit', (e) => {
                e.preventDefault();
                b2bForm.style.opacity = '0.5';
                b2bForm.style.pointerEvents = 'none';
                formLoader.style.display = 'block';
                formLoader.textContent = "Status: Transmitting Data...";

                const formData = new FormData(b2bForm);
                fetch("/", {
                    method: "POST",
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: new URLSearchParams(formData as any).toString()
                })
                .then(() => {
                    formLoader.textContent = "Status: Protocol Success";
                    setTimeout(() => {
                        window.location.href = '/success';
                    }, 800);
                })
                .catch(() => {
                    formLoader.textContent = "Status: System Error - Transmission Failed";
                    b2bForm.style.opacity = '1';
                    b2bForm.style.pointerEvents = 'auto';
                });
            });
        }
    });
</script>
