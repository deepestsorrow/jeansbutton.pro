---
import Layout from '../layouts/Layout.astro';

const title = "S.D.A.P. | Bespoke Luxury Metalworks ‚Äî Est. 2007";
const description = "SDAP (S&D Asia Pacific) ‚Äî Precision-engineered bespoke metalworks for denim hardware, luxury bag fittings, cigar humidor accessories, and fine jewelry components.";
---

<Layout title={title} description={description} isHome=true>
    <main class="editorial-flow">
        <!-- &rdquo;&rdquo;&rdquo; HERO SECTION &rdquo;&rdquo;&rdquo; -->
        <section class="editorial-hero" id="hero" aria-labelledby="hero-title">
            <picture style="display: block; position: absolute; inset: 0; z-index: 1;">
                <img src="/imgs/jewelry_pendant_hero.webp" alt="Bespoke Metalworks Macro" class="editorial-hero-img" width="1920" height="1080" fetchpriority="high">
            </picture>
            <div class="hero-scan-line" aria-hidden="true"></div>
            <div class="hero-hud-coordinates" aria-label="Geographic Coordinates and System Status">
                <span>30.7459&deg; N, 120.7555&deg; E</span>
                <span>TOLERANCE &plusmn;0.01MM</span>
                <span>CALIBRATION: ACTIVE</span>
            </div>
            <div class="editorial-hero-overlay"></div>
            <div class="editorial-hero-content">
                <h1 id="hero-title" class="editorial-hero-title">S.D.A.P.</h1>
                <p class="editorial-hero-sub">
                    <span class="sub-line-1">Bespoke Metalworks &mdash; Est. 2007</span>
                    <span class="sub-line-2">Denim ¬∑ Bags ¬∑ Cigars ¬∑ Fine Jewelry</span>
                </p>
            </div>
        </section>

        <!-- ‚îÄ‚îÄ TRUST STRIP ‚îÄ‚îÄ -->
        <section style="padding: 4rem var(--space-lg); border-bottom: 1px solid rgba(255,255,255,0.06); background: #050505;">
            <p style="text-align:center; font-family:var(--font-mono); font-size:0.6rem; letter-spacing:0.4em; text-transform:uppercase; color:rgba(255,255,255,0.4); margin-bottom:3rem; font-weight: 300;">Supplying the world&rsquo;s most demanding labels since 2007</p>
            <div class="trust-strip-logos" style="display:flex; justify-content:center; align-items:center; gap:clamp(2rem, 6vw, 6rem); flex-wrap:wrap; opacity: 0.65; filter: grayscale(0.7); transition: opacity 0.5s ease, filter 0.5s ease;" onmouseenter="this.style.opacity='0.9';this.style.filter='grayscale(0)';" onmouseleave="this.style.opacity='0.65';this.style.filter='grayscale(0.7)';">
                <span class="magnetic" style="font-family:var(--font-serif); font-size:clamp(1rem,2.2vw,1.4rem); letter-spacing:0.18em; font-weight:400; font-style: italic;">Oeko-Tex&reg;</span>
                <span class="magnetic" style="font-family:var(--font-serif); font-size:clamp(1rem,2.2vw,1.4rem); letter-spacing:0.18em; font-weight:400; font-style: italic;">ASTM International</span>
                <span class="magnetic" style="font-family:var(--font-serif); font-size:clamp(1rem,2.2vw,1.4rem); letter-spacing:0.18em; font-weight:400; font-style: italic;">ISO 9227</span>
                <span class="magnetic" style="font-family:var(--font-serif); font-size:clamp(1rem,2.2vw,1.4rem); letter-spacing:0.18em; font-weight:400; font-style: italic;">Ellen MacArthur Foundation</span>
                <span class="magnetic" style="font-family:var(--font-serif); font-size:clamp(1rem,2.2vw,1.4rem); letter-spacing:0.18em; font-weight:400; font-style: italic;">PETA Approved</span>
            </div>
        </section>

        <!-- &bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê
             01 &mdash; TACK BUTTONS
             &bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê -->
        <section class="category-section" id="tack-buttons">
            <a href="/tack-buttons" class="category-hero">
                <div class="lqip-container">
                <img src="/imgs/dark_button_opt.jpg" alt="Matte Black Tack Button" class="category-hero-img" loading="lazy" width="1920" height="1080" onload="this.setAttribute('data-loaded', 'true')">
            </div>
                <div class="category-hero-overlay"></div>
                <div class="category-hero-caption">
                    <span class="category-index">01</span>
                    <h2>Tack Buttons &amp; Shanks</h2>
                    <p>Aerospace-grade zinc alloys &amp; PVD Anti-oxidation</p>
                </div>
            </a>

            <div class="spec-panel">
                <div class="spec-content">
                    <div class="tech-content-block">
                        <h3>Detachable Monomaterial Framework</h3>
                        <p>Unlike traditional electroplated rivets, our new line of Tack Buttons feature a detachable mono-material framework designed explicitly for the circular economy. The button can be unscrewed via a proprietary micro-thread, allowing the denim to be fully recycled without the need to cut out the hardware.</p>
                    </div>
                    <div class="tech-content-block">
                        <h3>Molecular PVD Bonding & Hybrid Alloys</h3>
                        <p>Our buttons are engineered for heavy-duty denim weights exceeding 16oz. We utilize <strong>High-Vacuum PVD (Physical Vapor Deposition)</strong>, establishing a near-indestructible anti-oxidation barrier. This process bonds the finish at a molecular level, providing a Vickers Hardness (HV) rating 10x superior to standard electroplating. The base substrates consist of <strong>Zamak 5 die-castings</strong> for complex branding and <strong>H65 Brass</strong> for heritage-grade structural integrity.</p>
                    </div>

                    <ul class="tech-tabular-list" aria-label="Tack Button Specifications" data-reveal="scanner">
                        <li>Substrate <span>Zamak 5 (Die-Cast) / H65 Brass (Forged)</span></li>
                        <li>Hardness Profile <span>2500&ndash;3000 HV (PVD Molecular Coating)</span></li>
                        <li>Surface Durability <span>ASTM B117 - 120h High-Vaccum Pass</span></li>
                        <li>Wash Resistance <span>Industrial Stone-Wash & Enzyme (50+ Cycles)</span></li>
                        <li>Tensile Strength <span>&gt;850&nbsp;N (Reinforced Shank Core)</span></li>
                        <li>Certification <span>Oeko-Tex Standard 100 Class I</span></li>
                        <li>Precision <span>&plusmn;0.01&nbsp;mm High-Tolerance Tooling</span></li>
                        <li>Surface Option <span>Soft-Touch TPU/TPE Overmould (Skin-Safe)</span></li>
                        <li>Overmould Thickness <span>&plusmn;0.02&nbsp;mm Precision Bond Tolerance</span></li>
                    </ul>

                    <div class="tech-content-block">
                        <h3>Soft-Touch Rubber Overmoulding &mdash; Skin-Grade Haptics</h3>
                        <p>For labels demanding a premium <strong>tactile identity</strong>, we offer a full <strong>TPU / TPE Rubber Overmoulding</strong> process applied directly to the exposed button face. The result is a velvety, skin-feeling surface indistinguishable from the premium soft-touch found in luxury consumer electronics &mdash; zero cold metallic contact, pure warmth on touch. The rubber layer is precision-moulded at <strong>&plusmn;0.02&nbsp;mm thickness tolerance</strong>, ensuring a flush, bubble-free bond to the metal substrate beneath. Available in matte black, stone grey, bone white, and fully custom bespoke RAL colorways. Certified skin-safe to <strong>GB/T 17592 and OEKO-TEX&reg; Standard 100</strong>.</p>
                    </div>

                    <div class="tech-insight-grid">
                        <div class="tech-insight-card">
                            <span>Compliance</span>
                            <strong>Ellen MacArthur Foundation Circular</strong>
                        </div>
                        <div class="tech-insight-card">
                            <span>Future Trend</span>
                            <strong>Detachable &amp; Screw-Off Hardware</strong>
                        </div>
                        <div class="tech-insight-card">
                            <span>2026 Trend</span>
                            <strong>QR-Encoded Traceability Buttons</strong>
                        </div>
                        <div class="tech-insight-card">
                            <span>Finish Frontier</span>
                            <strong>Soft-Touch TPU Overmould</strong>
                        </div>
                    </div>

                    <div class="tech-qa-section">
                        <div class="qa-item">
                            <strong>Q: What is the defining trend for denim hardware at the luxury level?</strong>
                            <p>A: High-end labels are redesigning garments for "End-of-Life" (EOL) circularity. Screw-on/screw-off hardware is becoming mandatory so denim can be shredded and recycled instantly.</p>
                        </div>
                        <div class="qa-item">
                            <strong>Q: Are the PVD coatings susceptible to chipping?</strong>
                            <p>A: No. Unlike paint or standard electroplating, PVD is molecularly bonded to the alloy lattice, making it impervious to industrial stone-washing and standard chipping.</p>
                        </div>
                        <div class="qa-item">
                            <strong>Q: Do you offer a rubber or soft-touch coating on the button face?</strong>
                            <p>A: Yes. Our TPU/TPE Rubber Overmoulding wraps the exposed face in a skin-grade, velvety rubber finish &mdash; the same tactile technology used in luxury consumer electronics. It is warm to touch, completely matte, wash-stable across 50+ industrial cycles, and available in any bespoke RAL colorway.</p>
                        </div>
                        <div class="qa-item">
                            <strong>Q: Can you embed digital traceability into a button?</strong>
                            <p>A: Yes. We offer a micro-engraved QR code on the underside shank that links to a digital product passport &mdash; providing end consumers and recyclers with full material composition, origin, and end-of-life instructions. This is rapidly becoming a compliance requirement for EU textile regulations post-2026.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>


        <!-- &bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê
             02 &mdash; COPPER RIVETS
             &bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê -->
        <section class="category-section" id="rivets">
            <a href="/rivets" class="category-hero">
                <div class="lqip-container">
                <img src="/imgs/copper_rivet_opt.jpg" alt="Copper Denim Rivet" class="category-hero-img" loading="lazy" width="1920" height="1080" onload="this.setAttribute('data-loaded', 'true')">
            </div>
                <div class="category-hero-overlay"></div>
                <div class="category-hero-caption">
                    <span class="category-index">02</span>
                    <h2>CNC-Milled Burrs &amp; Rivets</h2>
                    <p>5-Axis CNC Milling &amp; Structural Enforcement</p>
                </div>
            </a>

            <div class="spec-panel">
                <div class="spec-content">
                    <div class="tech-content-block">
                        <h3>Cold-Forged H65 Brass Integrity & Ductility</h3>
                        <p>Our rivets are cold-forged from premium <strong>H65 Structural Brass</strong>, ensuring a dense molecular structure that resists deformation under extreme pocket-load stress. This specific alloy offers a <strong>35% Elongation Index</strong>, allowing for a perfect mushroomed seal without micro-fracturing. Each burr is high-vacuum PVD coated or chemically passivated to achieve <strong>ISO 9227 Accelerated Salt Spray benchmarks</strong> (96+ hours), ensuring heritage-grade patina without structural decay.</p>
                    </div>

                    <ul class="tech-tabular-list" aria-label="Rivet Specifications" data-reveal="scanner">
                        <li>Core Material <span>Pure H65 Brass / T1 Red Copper</span></li>
                        <li>Ductility Index <span>35% Elongation (ASTM E8)</span></li>
                        <li>Manufacture <span>Hardened Stamping & Cold Forging</span></li>
                        <li>Monogramming <span>5-Axis CNC Micro-Milling (&plusmn;0.005mm)</span></li>
                        <li>Anti-Oxidation <span>ISO 9227 Salt Spray (96h Pass)</span></li>
                        <li>Load Rating <span>&gt;850&nbsp;N (Reinforced Pocket-Stay)</span></li>
                        <li>Size Range <span>8&nbsp;mm / 9.5&nbsp;mm / 10&nbsp;mm</span></li>
                    </ul>

                    <div class="tech-insight-grid">
                        <div class="tech-insight-card">
                            <span>Compliance</span>
                            <strong>Zero-Water Discharge Plating</strong>
                        </div>
                        <div class="tech-insight-card">
                            <span>Future Trend</span>
                            <strong>Unsealed Living Patina Copper</strong>
                        </div>
                        <div class="tech-insight-card">
                            <span>2026 Trend</span>
                            <strong>Bar-Tack Replacement (Disassembly)</strong>
                        </div>
                        <div class="tech-insight-card">
                            <span>Sustainability</span>
                            <strong>Recycled Alloy Formulations</strong>
                        </div>
                    </div>

                    <div class="tech-qa-section">
                        <div class="qa-item">
                            <strong>Q: What is the current trend in denim rivets?</strong>
                            <p>A: Premium denim purists are demanding "Living Patinas"&mdash;completely unsealed raw copper that drastically oxidizes and ages alongside the fading indigo of the jeans.</p>
                        </div>
                        <div class="qa-item">
                            <strong>Q: Do you offer distinct burr profiles for extreme heavyweights?</strong>
                            <p>A: Yes. We engineer extended post lengths specifically structured to pierce and lock 21oz to 25oz super-heavyweight Japanese selvedge denim reliably.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>


        <!-- &bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê
             03 &mdash; STRUCTURAL IDENTIFIERS (PATCHES)
             &bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê&bull;¬ê -->
        <section class="category-section" id="patches">
            <a href="/patches" class="category-hero">
                <div class="lqip-container">
                <img src="/imgs/macro_patch_opt.jpg" alt="Jacron Denim Patch" class="category-hero-img" loading="lazy" width="1920" height="1080" onload="this.setAttribute('data-loaded', 'true')">
            </div>
                <div class="category-hero-overlay"></div>
                <div class="category-hero-caption">
                    <span class="category-index">03</span>
                    <h2>Structural Identifiers</h2>
                    <p>Laser Etched Jacron &amp; Vulcanized Leather</p>
                </div>
            </a>

            <div class="spec-panel">
                <div class="spec-content">
                    <div class="tech-content-block">
                        <h3>Sustainable Jacron & Vegan Bio-Polymers</h3>
                        <p>Our structural identifiers utilize high-density <strong>Cellulose Jacron</strong> and <strong>Mycelium (Mushroom) Leathers</strong>, offering a high-performance vegan alternative with zero visual compromise. The fibers are vulcanized at high pressure to ensure permanent tear resistance, even after repetitive industrial enzyme baths. We utilize non-toxic, bio-based adhesives for seamless garment integration.</p>
                    </div>

                    <ul class="tech-tabular-list" aria-label="Identifier Specifications">
                        <li>Substrates <span>Jacron Cellulose / Vulcanized Cork / Mycelium</span></li>
                        <li>Thermal Stability <span>Resistant up to 210&deg;C (Steam/Iron Safe)</span></li>
                        <li>Embossing Logic <span>100-Ton Hydraulic Cold-Press</span></li>
                        <li>Tear Resistance <span>ISO 3377-2 High-Tensile Rating</span></li>
                        <li>Print Precision <span>Micro-Fiber Laser Etching (Resolution &gt;600 DPI)</span></li>
                        <li>Thickness Delta <span>0.8&nbsp;mm &ndash; 3.0&nbsp;mm Custom Skiving</span></li>
                        <li>Wash Integrity <span>Zero Color Migration / Dimensionally Stable</span></li>
                    </ul>

                    <div class="tech-insight-grid">
                        <div class="tech-insight-card">
                            <span>Compliance</span>
                            <strong>100% PETA-Approved Vegan</strong>
                        </div>
                        <div class="tech-insight-card">
                            <span>Future Trend</span>
                            <strong>Mycelium (Mushroom) Leathers</strong>
                        </div>
                        <div class="tech-insight-card">
                            <span>2026 Trend</span>
                            <strong>NFC-Embedded Smart Patches</strong>
                        </div>
                        <div class="tech-insight-card">
                            <span>Process</span>
                            <strong>Bio-Based Zero-VOC Adhesives</strong>
                        </div>
                    </div>

                    <div class="tech-qa-section">
                        <div class="qa-item">
                            <strong>Q: What is the latest material trend in denim patches?</strong>
                            <p>A: High-end streetwear and luxury labels are moving fully away from animal hides towards Mycelium (mushroom leather) and post-consumer recycled cellulose blends with zero sacrifice to visual fidelity.</p>
                        </div>
                        <div class="qa-item">
                            <strong>Q: Can you laser-etch variable data (like serial numbers)?</strong>
                            <p>A: Yes. Because our etching is guided by 5-axis robotics, we can increment serial numbers or alter data on every single individual patch during a production batch.</p>
                        </div>
                    </div>
                </div>
            </div>
