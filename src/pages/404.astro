---
import Layout from '../layouts/Layout.astro';

const title = "404 Structural Anomaly | SDAP Precision Hardware";
const description = "";
---

<Layout title={title} description={description} isHome=false>
    <main class="legal-container">
        <h1 class="error-code">404</h1>
        <p class="error-desc">The portfolio slide or component spec you are looking for has been structurally detached from our blueprints.</p>
        <a href="/" class="return-btn magnetic">
            Return to Showroom
            <span style="font-size: 1.2rem;">→</span>
        </a>
    </main>
</Layout>
