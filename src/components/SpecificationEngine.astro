---
interface Props {
    type: 'button' | 'rivet' | 'patch' | 'bag' | 'cigar' | 'jewelry';
}

const { type } = Astro.props;

// Configurator presets
const presets = {
    button: {
        title: "Tack Button Specification",
        substrates: [
            { id: "zamak", name: "Zamak 5 Alloy", desc: "Complex die-cast detailing", co2: "1.8" },
            { id: "brass", name: "H65 Brass", desc: "Heritage forged rigidity", co2: "2.4" },
            { id: "steel", name: "Stainless Steel", desc: "Extreme durability core", co2: "3.2" }
        ],
        treatments: [
            { id: "raw", name: "Raw Tumbled", hardness: "120 HV", salt: "24h", tensile: "750 N" },
            { id: "electro", name: "Electroplated Trivalent", hardness: "180 HV", salt: "72h", tensile: "800 N" },
            { id: "pvd", name: "Vacuum PVD Matte Black", hardness: "2800 HV", salt: "120h", tensile: "880 N" },
            { id: "tpu", name: "Soft-Touch TPU Overmould", hardness: "95 Shore A", salt: "240h", tensile: "920 N" }
        ]
    },
    rivet: {
        title: "Copper Rivet & Burr Specification",
        substrates: [
            { id: "copper", name: "T1 Red Copper", desc: "Traditional living patina", co2: "1.2" },
            { id: "brass", name: "H65 Brass", desc: "High elongation index", co2: "2.4" }
        ],
        treatments: [
            { id: "raw", name: "Raw Unsealed", hardness: "90 HV", salt: "48h", tensile: "650 N" },
            { id: "passivated", name: "Chemical Passivation", hardness: "110 HV", salt: "96h", tensile: "720 N" },
            { id: "pvd", name: "Vacuum PVD Gunmetal", hardness: "2200 HV", salt: "144h", tensile: "850 N" }
        ]
    },
    patch: {
        title: "Structural Patch Specification",
        substrates: [
            { id: "brass", name: "H65 Brass Foil", desc: "Crisp embossed metallic edge", co2: "2.4" },
            { id: "aluminum", name: "Anodised Aluminium", desc: "Featherweight color variance", co2: "4.5" }
        ],
        treatments: [
            { id: "raw", name: "Raw Brushed", hardness: "80 HV", salt: "24h", tensile: "400 N" },
            { id: "anodised", name: "Alkaline Anodising", hardness: "350 HV", salt: "120h", tensile: "480 N" },
            { id: "pvd", name: "Vacuum PVD Rose Gold", hardness: "1800 HV", salt: "168h", tensile: "520 N" }
        ]
    },
    bag: {
        title: "Luxury Bag Hardware Specification",
        substrates: [
            { id: "brass", name: "H65 Forged Brass", desc: "Dense luxury hand-weight", co2: "2.4" },
            { id: "zamak", name: "Zamak 5 Zinc", desc: "Intricate geometric accuracy", co2: "1.8" },
            { id: "steel", name: "Surgical Stainless Steel", desc: "Ultra-high shear resistance", co2: "3.2" }
        ],
        treatments: [
            { id: "brushed", name: "Hand-Brushed Raw", hardness: "110 HV", salt: "48h", tensile: "1200 N" },
            { id: "electro", name: "Electroplated Palladium", hardness: "220 HV", salt: "96h", tensile: "1250 N" },
            { id: "pvd", name: "Vacuum PVD Gunmetal", hardness: "2500 HV", salt: "168h", tensile: "1400 N" }
        ]
    },
    cigar: {
        title: "Humidor Quadrant Hinge Specification",
        substrates: [
            { id: "brass", name: "Solid H65 Brass", desc: "Traditional low-friction core", co2: "2.4" },
            { id: "steel", name: "Surgical Stainless Steel", desc: "Non-corrosive heavy load", co2: "3.2" }
        ],
        treatments: [
            { id: "polished", name: "Zaratsu Hand-Polished", hardness: "115 HV", salt: "72h", tensile: "1800 N" },
            { id: "gold", name: "24K Gold Electroplating", hardness: "200 HV", salt: "120h", tensile: "1850 N" },
            { id: "pvd", name: "Vacuum PVD Matte Black", hardness: "2800 HV", salt: "240h", tensile: "2000 N" }
        ]
    },
    jewelry: {
        title: "Fine Jewelry Bezel Specification",
        substrates: [
            { id: "platinum", name: "Platinum 950", desc: "Superior prong ductility", co2: "5.5" },
            { id: "gold", name: "18K White Gold", desc: "High rigidity alloy", co2: "4.8" },
            { id: "yellow", name: "18K Yellow Gold", desc: "Classic luxury warmth", co2: "4.2" }
        ],
        treatments: [
            { id: "zaratsu", name: "Zaratsu Mirror Polish", hardness: "125 HV", salt: "168h", tensile: "950 N" },
            { id: "pvd", name: "0.5µm PVD Vermeil", hardness: "380 HV", salt: "240h", tensile: "980 N" }
        ]
    }
};

const currentPreset = presets[type];
---

<div class="spec-engine-container" data-type={type}>
    <div class="spec-engine-inner">
        <!-- Control Board -->
        <div class="spec-engine-controls">
            <h4 class="spec-engine-section-title">Telemetry Configurator</h4>
            
            <!-- Substrate Selector -->
            <div class="control-group">
                <label class="control-label">Metal Substrate</label>
                <div class="option-grid">
                    {currentPreset.substrates.map((sub, index) => (
                        <button 
                            class={`option-btn substrate-btn ${index === 0 ? 'active' : ''}`}
                            data-id={sub.id}
                            data-co2={sub.co2}
                            data-desc={sub.desc}
                            aria-label={`Select substrate ${sub.name}`}
                        >
                            <span class="btn-indicator"></span>
                            <span class="btn-text">{sub.name}</span>
                        </button>
                    ))}
                </div>
                <p class="substrate-description-text">{currentPreset.substrates[0].desc}</p>
            </div>

            <!-- Treatment Selector -->
            <div class="control-group" style="margin-top: 1.5rem;">
                <label class="control-label">Surface Treatment / Finish</label>
                <div class="option-grid">
                    {currentPreset.treatments.map((tr, index) => (
                        <button 
                            class={`option-btn treatment-btn ${index === 0 ? 'active' : ''}`}
                            data-id={tr.id}
                            data-hardness={tr.hardness}
                            data-salt={tr.salt}
                            data-tensile={tr.tensile}
                            aria-label={`Select treatment ${tr.name}`}
                        >
                            <span class="btn-indicator"></span>
                            <span class="btn-text">{tr.name}</span>
                        </button>
                    ))}
                </div>
            </div>
        </div>

        <!-- Telemetry & Blueprint Output -->
        <div class="spec-engine-visualiser">
            <!-- CAD Blueprint Display -->
            <div class="blueprint-frame">
                <div class="blueprint-label">
                    <span>SYSTEM: CAD_SCHEMATIC_{type.toUpperCase()}</span>
                    <span>SCALE: 5:1</span>
                </div>
                
                <div class="blueprint-vector-wrapper">
                    {type === 'button' && (
                        <svg viewBox="0 0 200 200" class="blueprint-svg" aria-label="Button CAD Drawing">
                            <!-- Button Cap -->
                            <path d="M 40,80 L 160,80 Q 170,80 170,95 L 170,105 Q 170,115 160,115 L 40,115 Q 30,115 30,105 L 30,95 Q 30,80 40,80 Z" class="cad-metal-part" />
                            <!-- Outer Ring Overmould Indicator -->
                            <rect x="25" y="93" width="150" height="24" rx="3" class="cad-overmould-part" style="display: none; fill: none; stroke: var(--accent-light); stroke-dasharray: 4 2; stroke-width: 1.5;" />
                            <!-- Button Shank Core -->
                            <rect x="85" y="115" width="30" height="40" class="cad-metal-part" />
                            <!-- Bottom Base -->
                            <path d="M 70,155 L 130,155 L 140,165 L 60,165 Z" class="cad-metal-part" />
                            
                            <!-- Dimension Lines -->
                            <line x1="20" y1="80" x2="20" y2="115" class="cad-dim-line" />
                            <line x1="15" y1="80" x2="25" y2="80" class="cad-dim-line" />
                            <line x1="15" y1="115" x2="25" y2="115" class="cad-dim-line" />
                            <text x="10" y="102" class="cad-dim-text">14mm</text>

                            <line x1="30" y1="180" x2="170" y2="180" class="cad-dim-line" />
                            <line x1="30" y1="175" x2="30" y2="185" class="cad-dim-line" />
                            <line x1="170" y1="175" x2="170" y2="185" class="cad-dim-line" />
                            <text x="100" y="195" class="cad-dim-text" text-anchor="middle">Ø 17.0mm</text>
                        </svg>
                    )}

                    {type === 'rivet' && (
                        <svg viewBox="0 0 200 200" class="blueprint-svg" aria-label="Rivet CAD Drawing">
                            <!-- Burr/Cap -->
                            <ellipse cx="100" cy="75" rx="45" ry="12" class="cad-metal-part" />
                            <rect x="88" y="75" width="24" height="60" class="cad-metal-part" />
                            <!-- Bottom Head -->
                            <ellipse cx="100" cy="135" rx="35" ry="10" class="cad-metal-part" />
                            
                            <!-- Dimensions -->
                            <line x1="45" y1="75" x2="45" y2="135" class="cad-dim-line" />
                            <text x="35" y="110" class="cad-dim-text">9.5mm</text>
                            
                            <line x1="55" y1="160" x2="145" y2="160" class="cad-dim-line" />
                            <text x="100" y="178" class="cad-dim-text" text-anchor="middle">BURR Ø 9.5mm</text>
                        </svg>
                    )}

                    {type === 'patch' && (
                        <svg viewBox="0 0 200 200" class="blueprint-svg" aria-label="Patch CAD Drawing">
                            <!-- Metal Plate -->
                            <rect x="40" y="50" width="120" height="100" rx="8" class="cad-metal-part" />
                            <!-- Stitch holes -->
                            <rect x="48" y="58" width="104" height="84" rx="4" style="fill: none; stroke: var(--accent-color); stroke-dasharray: 6 4; stroke-width: 1;" />
                            <!-- Logo Circle in middle -->
                            <circle cx="100" cy="100" r="25" style="fill: none; stroke: var(--accent-color); stroke-width: 1;" />
                            <text x="100" y="104" class="cad-dim-text" text-anchor="middle" style="font-size: 8px;">SDAP</text>
                            
                            <!-- Dimensions -->
                            <line x1="25" y1="50" x2="25" y2="150" class="cad-dim-line" />
                            <text x="18" y="105" class="cad-dim-text">50mm</text>
                            <line x1="40" y1="170" x2="160" y2="170" class="cad-dim-line" />
                            <text x="100" y="185" class="cad-dim-text" text-anchor="middle">60mm</text>
                        </svg>
                    )}

                    {type === 'bag' && (
                        <svg viewBox="0 0 200 200" class="blueprint-svg" aria-label="Lock CAD Drawing">
                            <!-- Lock Outer Plate -->
                            <rect x="50" y="50" width="100" height="100" rx="12" class="cad-metal-part" />
                            <!-- Turnlock knob -->
                            <rect x="85" y="85" width="30" height="30" rx="4" class="cad-metal-part" />
                            <line x1="100" y1="75" x2="100" y2="125" style="stroke: var(--accent-color); stroke-width: 1.5; stroke-dasharray: 2 2;" />
                            
                            <!-- Dimension lines -->
                            <line x1="35" y1="50" x2="35" y2="150" class="cad-dim-line" />
                            <text x="28" y="105" class="cad-dim-text">40mm</text>
                        </svg>
                    )}

                    {type === 'cigar' && (
                        <svg viewBox="0 0 200 200" class="blueprint-svg" aria-label="Hinge CAD Drawing">
                            <!-- Left leaf -->
                            <path d="M 50,60 L 95,60 L 95,140 L 50,140 Z" class="cad-metal-part" />
                            <!-- Pin Joint / Barrel -->
                            <rect x="95" y="50" width="10" height="100" rx="3" style="fill: var(--bg-secondary); stroke: var(--accent-color); stroke-width: 1.5;" />
                            <!-- Right leaf -->
                            <path d="M 105,60 L 150,60 L 150,140 L 105,140 Z" class="cad-metal-part" />
                            <!-- Screw Holes -->
                            <circle cx="70" cy="80" r="4" style="fill: none; stroke: var(--accent-color);" />
                            <circle cx="70" cy="120" r="4" style="fill: none; stroke: var(--accent-color);" />
                            <circle cx="130" cy="80" r="4" style="fill: none; stroke: var(--accent-color);" />
                            <circle cx="130" cy="120" r="4" style="fill: none; stroke: var(--accent-color);" />
                        </svg>
                    )}

                    {type === 'jewelry' && (
                        <svg viewBox="0 0 200 200" class="blueprint-svg" aria-label="Ring CAD Drawing">
                            <!-- Ring Band -->
                            <circle cx="100" cy="115" r="50" style="fill: none; stroke: var(--accent-color); stroke-width: 4;" />
                            <!-- Prong setting head -->
                            <path d="M 85,65 L 75,45 L 82,45 L 90,60 Z" class="cad-metal-part" />
                            <path d="M 115,65 L 125,45 L 118,45 L 110,60 Z" class="cad-metal-part" />
                            <!-- Solitaire Gem -->
                            <polygon points="100,75 80,50 90,40 110,40 120,50" style="fill: none; stroke: var(--accent-light); stroke-width: 1.5;" />
                        </svg>
                    )}
                </div>
            </div>

            <!-- Specs Grid output -->
            <div class="telemetry-grid">
                <div class="telemetry-metric">
                    <span class="metric-label">Vickers Hardness</span>
                    <strong class="metric-value" id="val-hardness">{currentPreset.treatments[0].hardness}</strong>
                </div>
                <div class="telemetry-metric">
                    <span class="metric-label">ASTM Corrosion Proof</span>
                    <strong class="metric-value" id="val-salt">{currentPreset.treatments[0].salt}</strong>
                </div>
                <div class="telemetry-metric">
                    <span class="metric-label">Core Tensile Limit</span>
                    <strong class="metric-value" id="val-tensile">{currentPreset.treatments[0].tensile}</strong>
                </div>
                <div class="telemetry-metric">
                    <span class="metric-label">CO2-e Emissions</span>
                    <strong class="metric-value" id="val-co2">{currentPreset.substrates[0].co2} kg/kg</strong>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const engines = document.querySelectorAll('.spec-engine-container');
        
        engines.forEach(engine => {
            const substrateBtns = engine.querySelectorAll('.substrate-btn');
            const treatmentBtns = engine.querySelectorAll('.treatment-btn');
            const descText = engine.querySelector('.substrate-description-text');
            
            // Outputs
            const hardnessVal = engine.querySelector('#val-hardness');
            const saltVal = engine.querySelector('#val-salt');
            const tensileVal = engine.querySelector('#val-tensile');
            const co2Val = engine.querySelector('#val-co2');
            
            // CAD elements
            const svg = engine.querySelector('.blueprint-svg');
            const metalParts = engine.querySelectorAll('.cad-metal-part');
            const overmouldPart = engine.querySelector('.cad-overmould-part') as HTMLElement;
            
            // Substrate selection click handler
            substrateBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    substrateBtns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    
                    const desc = btn.getAttribute('data-desc') || '';
                    const co2 = btn.getAttribute('data-co2') || '';
                    const subId = btn.getAttribute('data-id') || '';
                    
                    if (descText) descText.textContent = desc;
                    if (co2Val) co2Val.textContent = `${co2} kg/kg`;
                    
                    // Dynamically recolor CAD blueprint parts to simulate metals
                    let color = 'rgba(255, 255, 255, 0.4)';
                    if (subId === 'brass') color = '#e0c068'; // brassy gold
                    else if (subId === 'copper') color = '#c87050'; // copper rose
                    else if (subId === 'steel' || subId === 'platinum') color = '#a8b0c0'; // polished steel
                    else if (subId === 'aluminum') color = '#8cb0c0'; // anodized aluminum
                    
                    metalParts.forEach(part => {
                        (part as HTMLElement).style.stroke = color;
                    });
                });
            });

            // Treatment selection click handler
            treatmentBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    treatmentBtns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    
                    const hardness = btn.getAttribute('data-hardness') || '';
                    const salt = btn.getAttribute('data-salt') || '';
                    const tensile = btn.getAttribute('data-tensile') || '';
                    const treatId = btn.getAttribute('data-id') || '';
                    
                    if (hardnessVal) hardnessVal.textContent = hardness;
                    if (saltVal) saltVal.textContent = salt;
                    if (tensileVal) tensileVal.textContent = tensile;
                    
                    // Specially handle Overmould indicator in button blueprint
                    if (overmouldPart) {
                        if (treatId === 'tpu') {
                            overmouldPart.style.display = 'block';
                        } else {
                            overmouldPart.style.display = 'none';
                        }
                    }
                });
            });
            
            // Initialize default visual representation
            const firstSubId = substrateBtns[0]?.getAttribute('data-id') || '';
            let defaultColor = 'rgba(255, 255, 255, 0.4)';
            if (firstSubId === 'brass') defaultColor = '#e0c068';
            else if (firstSubId === 'copper') defaultColor = '#c87050';
            else if (firstSubId === 'platinum') defaultColor = '#a8b0c0';
            
            metalParts.forEach(part => {
                (part as HTMLElement).style.stroke = defaultColor;
                (part as HTMLElement).style.fill = 'none';
                (part as HTMLElement).style.strokeWidth = '1.5px';
                (part as HTMLElement).style.transition = 'stroke 0.4s ease';
            });
        });
    });
</script>

<style>
    .spec-engine-container {
        --accent-color: rgba(255, 255, 255, 0.2);
        --accent-light: rgba(255, 255, 255, 0.6);
        margin: var(--space-lg) 0;
        padding: var(--space-md);
        background: rgba(10, 11, 16, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        backdrop-filter: blur(12px);
    }
    
    .spec-engine-inner {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: var(--space-md);
    }
    
    @media (max-width: 900px) {
        .spec-engine-inner {
            grid-template-columns: 1fr;
        }
    }
    
    .spec-engine-section-title {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--accent-color);
        margin-bottom: 1.5rem;
        border-bottom: 1px dashed rgba(255, 255, 255, 0.15);
        padding-bottom: 0.5rem;
    }
    
    .control-group {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }
    
    .control-label {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(255, 255, 255, 0.5);
    }
    
    .option-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.5rem;
    }
    
    .option-btn {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 6px;
        padding: 0.7rem 1rem;
        color: rgba(255, 255, 255, 0.85);
        font-family: var(--font-sans);
        font-size: 0.8rem;
        text-align: left;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease;
    }
    
    .option-btn:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.2);
    }
    
    .option-btn.active {
        background: rgba(255, 255, 255, 0.08);
        border-color: var(--accent-color);
        color: #fff;
    }
    
    .btn-indicator {
        display: block;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.2);
        transition: background 0.3s ease, box-shadow 0.3s ease;
    }
    
    .option-btn.active .btn-indicator {
        background: var(--accent-light);
        box-shadow: 0 0 8px var(--accent-light);
    }
    
    .substrate-description-text {
        font-family: var(--font-sans);
        font-size: 0.75rem;
        line-height: 1.5;
        color: rgba(255, 255, 255, 0.4);
        margin: 0.3rem 0 0 0;
    }
    
    .spec-engine-visualiser {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
        border-left: 1px solid rgba(255, 255, 255, 0.06);
        padding-left: var(--space-md);
    }
    
    @media (max-width: 900px) {
        .spec-engine-visualiser {
            border-left: none;
            padding-left: 0;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            padding-top: var(--space-md);
        }
    }
    
    .blueprint-frame {
        flex: 1;
        min-height: 180px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        background: radial-gradient(circle at center, rgba(10, 20, 40, 0.15) 0%, rgba(0, 0, 0, 0) 100%), #040508;
        border-radius: 8px;
        padding: 0.8rem;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
    }
    
    .blueprint-label {
        display: flex;
        justify-content: space-between;
        font-family: var(--font-mono);
        font-size: 0.5rem;
        color: rgba(255, 255, 255, 0.35);
        letter-spacing: 0.08em;
    }
    
    .blueprint-vector-wrapper {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
    }
    
    .blueprint-svg {
        width: 100%;
        max-width: 160px;
        height: auto;
        opacity: 0.95;
    }
    
    .cad-dim-line {
        stroke: rgba(255, 255, 255, 0.2);
        stroke-width: 0.8px;
    }
    
    .cad-dim-text {
        fill: rgba(255, 255, 255, 0.4);
        font-family: var(--font-mono);
        font-size: 6px;
    }
    
    .telemetry-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.6rem;
    }
    
    .telemetry-metric {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 6px;
        padding: 0.6rem 0.8rem;
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
    }
    
    .metric-label {
        font-family: var(--font-mono);
        font-size: 0.5rem;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.45);
        letter-spacing: 0.08em;
    }
    
    .metric-value {
        font-family: var(--font-sans);
        font-size: 0.85rem;
        font-weight: 500;
        color: #fff;
    }
</style>
